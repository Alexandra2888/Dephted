# Supabase
SUPABASE_URL=                       # https://<project-ref>.supabase.co (used for JWKS + DB)
SUPABASE_JWT_SECRET=                # ONLY needed if your project still issues legacy HS256 tokens
                                    # (Settings → JWT Keys → Legacy JWT Secret tab). New projects
                                    # use ES256/RS256 — verified via JWKS, leave this blank.
SUPABASE_SERVICE_ROLE_KEY=          # reserved for Phase B. New format: sb_secret_*
                                    # Settings → API Keys → Secret keys

# Database — Supabase Postgres. Use the SESSION pooler (port 5432), not the
# transaction pooler (6543): the LangGraph checkpointer needs session-scoped
# prepared statements. Settings → Database → Connection string → Session pooler.
DATABASE_URL=

# Models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Tracing — Phoenix (Arize). Leave blank to disable tracing.
# Cloud: https://app.phoenix.arize.com/v1/traces  +  your Phoenix API key.
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_API_KEY=

# CORS — comma-separated origins (Next dev may run on 3000 or 3001)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO
